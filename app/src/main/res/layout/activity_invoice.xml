<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="INVOICE"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvInvoiceId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Order ID: #123" />

        <TextView
            android:id="@+id/tvInvoiceDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date: 2023-10-27" />

        <TextView
            android:id="@+id/tvInvoiceUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Customer: Admin" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#CCCCCC" />

        <LinearLayout
            android:id="@+id/llInvoiceDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#CCCCCC" />

        <TextView
            android:id="@+id/tvInvoiceTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="20sp"
            android:textStyle="bold"
            android:text="Total: $0.00" />

        <Button
            android:id="@+id/btnBackHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Back to Home" />

    </LinearLayout>
</ScrollView>
